# ============================================================
# 混凝土课程设计计算平台 — 环境变量配置
# 复制此文件为 .env 并根据需要修改：
#   copy .env.example .env
# ============================================================

# JWT 签名密钥（生产环境务必修改为随机字符串）
# SECRET_KEY=dev-insecure-change-me-please-override-in-production

# CORS 允许的源（逗号分隔多个源）
# CORS_ORIGINS=http://localhost:3000

# 是否托管前端静态文件（便携版启用：1 / true / yes）
# SERVE_STATIC=

# 静态文件目录（SERVE_STATIC 启用时有效）
# STATIC_DIR=

# 服务端口（仅 run.py / PyInstaller 便携版生效）
# PORT=8000
